{
  "expo": {
    "name": "tst",
    "slug": "tst",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/AutonomousLogo.jpeg",
    "scheme": "tst",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/AutonomousLogo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/AutonomousLogo.jpeg",
        "backgroundColor": "#000000"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/AutonomousLogo.jpeg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ahmed_2558.tst"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID for secure and convenient login."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
